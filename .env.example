# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=YOUR_VALUE_HERE
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=

# ── S3 ────────────────────────────────────────────────────────────────────────
# public   → direct https://bucket.s3.region.amazonaws.com/... URL
# presigned → signed URL with expiry (default, works with private buckets)
S3_URL_STRATEGY=presigned
S3_SIGNED_URL_EXPIRY=86400

# ── Chrome ────────────────────────────────────────────────────────────────────
CHROME_DIR=YOUR_VALUE_HERE
CHROME_DOWNLOAD_TIMEOUT=120000

# ── Render ────────────────────────────────────────────────────────────────────
DEFAULT_COMPOSITION=StaticSlot
RENDER_TIMEOUT=600000
RENDER_CONCURRENCY=1
VIDEO_CRF=23
FRAME_TIMEOUT=120000

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info

# ── Auth ──────────────────────────────────────────────────────────────────────
AI_VIDEO_SERVICE_TOKEN=

# ── Callback ──────────────────────────────────────────────────────────────────
CALLBACK_MAX_RETRIES=3
CALLBACK_TIMEOUT_MS=10000
CALLBACK_RETRY_BASE_DELAY_MS=1000

# ── Thumbnail ─────────────────────────────────────────────────────────────────
THUMBNAIL_ENABLED=1
THUMBNAIL_FRAME_INDEX=0
